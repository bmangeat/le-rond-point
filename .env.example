# ─── Base de données (Neon PostgreSQL) ────────────────────────────────────────
# Récupérer sur https://console.neon.tech → votre projet → Connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
AUTH_SECRET="your-random-secret-here"

# URL de base de l'app (ex: http://localhost:3000 en dev, https://lerondpoint.vercel.app en prod)
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Créer sur https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs : http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─── Resend (emails) ──────────────────────────────────────────────────────────
# Récupérer sur https://resend.com → API Keys
RESEND_API_KEY="re_your_api_key"

# Email expéditeur (doit correspondre à un domaine vérifié dans Resend)
# En dev, utiliser "onboarding@resend.dev" (limité à votre propre email)
RESEND_FROM="Le Rond Point <notifications@votre-domaine.com>"
